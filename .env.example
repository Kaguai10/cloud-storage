# Flask Environment
FLASK_ENV=development

# PostgreSQL Database
POSTGRES_USER=clouduserdb
POSTGRES_PASSWORD=cloudpassdb_secure2026
POSTGRES_DB=clouddb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# MinIO Object Storage
MINIO_ROOT_USER=adminminio
MINIO_ROOT_PASSWORD=MinioSecret2026!
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=cloud-storage
MINIO_CONSOLE_PORT=9001

# Security & Secrets
SECRET_KEY=super-secret-key-change-in-production-2026!
JWT_SECRET=jwt-super-secret-key-2026-change-me!

# Application Settings
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,bmp

# Logging
LOG_LEVEL=INFO
LOG_DIR=/app/logs
